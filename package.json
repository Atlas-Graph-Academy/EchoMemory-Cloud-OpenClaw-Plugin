{
  "name": "@echomem/echo-memory-cloud-openclaw-plugin",
  "version": "0.1.2",
  "description": "OpenClaw plugin for syncing local markdown memory files to Echo cloud",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "lib/*.js",
    "lib/local-ui/dist/",
    "openclaw.plugin.json",
    "moltbot.plugin.json",
    "clawdbot.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "author": "EchoMem",
  "repository": {
    "type": "git",
    "url": "https://github.com/Atlas-Graph-Academy/EchoMemory-Cloud-OpenClaw-Plugin.git"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "echomem",
    "openclaw",
    "plugin",
    "memory",
    "markdown"
  ],
  "scripts": {
    "sync-version": "node scripts/sync-version.js",
    "version": "npm run sync-version && git add openclaw.plugin.json moltbot.plugin.json clawdbot.plugin.json"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  },
  "moltbot": {
    "extensions": [
      "./index.js"
    ]
  },
  "clawdbot": {
    "extensions": [
      "./index.js"
    ]
  }
}
