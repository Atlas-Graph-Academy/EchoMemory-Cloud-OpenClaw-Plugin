# Example .env file for Echo Memory Cloud OpenClaw Plugin
# IMPORTANT: This file is just a template. To use these settings in production,
# rename/copy this file to `.env` or `.env.local` (depending on your setup)
# or place it at `~/.openclaw/.env`.

# The base URL of the Echo Memory Cloud API
ECHOMEM_BASE_URL="https://echo-mem-chrome.vercel.app/"

# Your API Key for Echo Memory Cloud
ECHOMEM_API_KEY="Your Echo Memory Cloud API Key"
