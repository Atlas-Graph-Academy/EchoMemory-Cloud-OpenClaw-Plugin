{
  "id": "echo-memory-cloud-openclaw-plugin",
  "name": "Echo Memory Cloud OpenClaw Plugin",
  "description": "Sync OpenClaw local markdown memory files to Echo cloud",
  "version": "0.1.0",
  "kind": "lifecycle",
  "main": "./index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "baseUrl": {
        "type": "string",
        "description": "Echo backend base URL, for example https://your-echo-host.com"
      },
      "apiKey": {
        "type": "string",
        "description": "Echo API key. Falls back to ECHOMEM_API_KEY from ~/.openclaw/.env, ~/.moltbot/.env, ~/.clawdbot/.env, or process env."
      },
      "autoSync": {
        "type": "boolean",
        "default": true
      },
      "syncIntervalMinutes": {
        "type": "integer",
        "default": 15,
        "minimum": 1
      },
      "batchSize": {
        "type": "integer",
        "default": 10,
        "minimum": 1,
        "maximum": 25
      },
      "requestTimeoutMs": {
        "type": "integer",
        "default": 300000,
        "minimum": 1000
      }
    },
    "additionalProperties": false
  }
}
